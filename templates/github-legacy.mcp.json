{
  "schema": "openstaff.mcp-template.v1",
  "template_id": "builtin.github.legacy",
  "key": "github",
  "display_name": "GitHub",
  "description": "GitHub API 操作：仓库管理、Issue/PR 操作、代码搜索等",
  "category": "dev-tools",
  "icon": "github",
  "logo": "https://cdn.simpleicons.org/github?viewbox=auto",
  "source": "builtin-current-seed",
  "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/github",
  "match_hints": {
    "name": "GitHub",
    "npm_package": "@modelcontextprotocol/server-github",
    "pypi_package": null
  },
  "profiles": [
    {
      "id": "package-npm",
      "profile_type": "package",
      "transport_type": "stdio",
      "runner_kind": "package",
      "runner": "npx",
      "ecosystem": "npm",
      "package_name": "@modelcontextprotocol/server-github",
      "package_version": "latest",
      "command": "npx",
      "args_template": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env_template": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${param:accessToken}"
      },
      "working_directory_template": "${param:workingDirectory}"
    }
  ],
  "parameter_schema": [
    {
      "key": "accessToken",
      "label": "GitHub Personal Access Token",
      "type": "password",
      "required": true,
      "default_value": "",
      "description": "PAT used by the legacy npm GitHub MCP server.",
      "applies_to_profiles": [
        "package-npm"
      ]
    },
    {
      "key": "workingDirectory",
      "label": "Working Directory",
      "type": "string",
      "required": false,
      "default_value": "${project.workspace}",
      "description": "Process working directory for local launch.",
      "applies_to_profiles": [
        "package-npm"
      ]
    }
  ]
}
