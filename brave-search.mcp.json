{
  "schema": "openstaff.mcp-template.v1",
  "template_id": "builtin.brave-search.legacy",
  "key": "brave-search",
  "display_name": "Brave Search",
  "description": "使用 Brave Search API 进行网页搜索和本地搜索",
  "category": "search",
  "icon": "search",
  "logo": "https://cdn.simpleicons.org/brave-search?viewbox=auto",
  "source": "builtin-current-seed",
  "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/brave-search",
  "match_hints": {
    "name": "Brave Search",
    "npm_package": "@modelcontextprotocol/server-brave-search",
    "pypi_package": null
  },
  "profiles": [
    {
      "id": "package-npm",
      "profile_type": "package",
      "transport_type": "stdio",
      "runner_kind": "package",
      "runner": "npx",
      "ecosystem": "npm",
      "package_name": "@modelcontextprotocol/server-brave-search",
      "package_version": "latest",
      "command": "npx",
      "args_template": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env_template": {
        "BRAVE_API_KEY": "${param:apiKey}"
      }
    }
  ],
  "parameter_schema": [
    {
      "key": "apiKey",
      "label": "Brave API Key",
      "type": "password",
      "required": true,
      "default_value": "",
      "description": "API key used by Brave Search MCP."
    }
  ]
}
